---
import '../styles/tokens.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-sc';
import { ClientRouter } from 'astro:transitions';
import HeadMeta from '../components/HeadMeta.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'zh';
  /** counterpart URL in the other language (nav switcher) */
  altHref: string;
  ogImage?: string;
  /** draft previews only — never let an unpublished page into a search index */
  noindex?: boolean;
}
const { title, description, lang, altHref, ogImage, noindex = false } = Astro.props;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <HeadMeta {title} {description} {lang} {ogImage} path={Astro.url.pathname} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <ClientRouter />
    <script is:inline>
      // Theme + JS flags before first paint (no FOUC). Stored choice wins;
      // otherwise the dark brand is the default on every surface.
      (() => {
        const apply = () => {
          const t = localStorage.getItem('theme');
          if (t === 'light') document.documentElement.dataset.theme = 'light';
          else delete document.documentElement.dataset.theme;
          document.documentElement.classList.add('js');
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
  </head>
  <script>
    // Stardust transition overlay: particles slowly surface on click-nav,
    // drift, and dissolve once the new page has condensed.
    function stardust() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const layer = document.createElement('div');
      layer.className = 'stardust-layer';
      const gold = getComputedStyle(document.documentElement).getPropertyValue('--color-gold').trim() || '#dda25b';
      for (let i = 0; i < 42; i++) {
        const s = document.createElement('span');
        const size = 1 + Math.random() * 2.6;
        s.style.width = `${size}px`;
        s.style.height = `${size}px`;
        s.style.left = `${Math.random() * 100}%`;
        s.style.top = `${Math.random() * 100}%`;
        if (Math.random() < 0.18) s.style.setProperty('--sd-color', gold);
        layer.appendChild(s);
        s.animate(
          [
            { opacity: 0, transform: 'translateY(6px) scale(0.6)' },
            { opacity: 0.9, transform: 'translateY(-4px) scale(1)', offset: 0.45 },
            { opacity: 0, transform: `translateY(-${10 + Math.random() * 14}px) scale(0.7)` },
          ],
          { duration: 1000 + Math.random() * 500, delay: Math.random() * 320, easing: 'ease-in-out', fill: 'forwards' },
        );
      }
      document.body.appendChild(layer);
      setTimeout(() => layer.remove(), 2100);
    }
    // after-swap: the old body (and anything appended to it) is discarded at
    // the swap — particles must live on the NEW body to be seen at all.
    document.addEventListener('astro:after-swap', stardust);
  </script>
  <body class="bg-bg font-sans text-ink antialiased">
    <Nav {lang} {altHref} />
    <slot />
    <Footer {lang} />
    <ChatWidget {lang} />
  </body>
</html>
