---
/**
 * Article layout. 2026-07-17 Yeqiu: episodes get the cosmic effects layer too —
 * the ambient (non-interactive, quieter) variant sits fixed behind the text.
 * KaTeX CSS is self-hosted via npm (no CDN); lightbox = medium-zoom on article images.
 */
import 'katex/dist/katex.min.css';
import Base from './Base.astro';
import BackgroundEquations from '../components/BackgroundEquations.astro';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'zh';
  altHref: string;
  date: Date;
  tags?: string[];
  ogImage?: string;
  series?: {
    id: string;
    title: string;
    order?: number;
    total: number;
    prev: { title: string; href: string } | null;
    next: { title: string; href: string } | null;
  } | null;
  /** draft preview route only: keep it out of search indexes */
  noindex?: boolean;
  /** draft preview route only: say so on the page, so a shared link is never mistaken for published */
  draftBanner?: boolean;
}
const {
  title, description, lang, altHref, date, tags = [], ogImage, series = null,
  noindex = false, draftBanner = false,
} = Astro.props;
const cover = ogImage; // feature image doubles as the in-page hero (Ghost Source parity)
const dateStr = date.toISOString().slice(0, 10);
---

<Base {title} {description} {lang} {altHref} {ogImage} {noindex}>
  <BackgroundEquations variant="ambient" />
  <main class="mx-auto max-w-2xl px-6 py-12">
    {draftBanner && (
      <p class="mb-8 rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm leading-relaxed text-amber-200/90">
        <strong>草稿预览</strong> —— 这篇还没有发布。它不在首页、文章列表、系列页、RSS 和站点地图里，
        只有拿到这个链接的人能看到。发布后它会换到正式地址。
      </p>
    )}
    {cover && (
      <img
        src={cover}
        alt=""
        class="no-zoom mb-10 w-full rounded-lg border border-line/60 object-cover"
        loading="eager"
      />
    )}
    <header class="mb-10">
      {series && (
        <p class="mb-3 text-sm text-muted">
          <a href={`/zh/series/${series.id}/`} class="text-accent-soft hover:underline">{series.title}</a>
          {series.order != null && <span class="text-faint"> · 第 {series.order} 篇 / 共 {series.total} 篇</span>}
        </p>
      )}
      <h1 class="text-3xl font-semibold leading-snug text-chalk">{title}</h1>
      <p class="mt-3 flex flex-wrap items-center gap-3 text-sm text-muted">
        <time datetime={dateStr}>{dateStr}</time>
        {tags.map((t) => <span class="rounded border border-line px-1.5 py-0.5 text-xs">{t}</span>)}
      </p>
    </header>
    <article class="article">
      <slot />
    </article>
    {series && (series.prev || series.next) && (
      <nav class="mt-12 grid gap-3 sm:grid-cols-2">
        {series.prev ? (
          <a href={series.prev.href} class="rounded-lg border border-line/70 bg-surface/40 p-4 transition-colors hover:border-accent-soft/60 hover:bg-surface">
            <span class="text-xs text-faint">← 上一篇</span>
            <span class="mt-1 block text-sm text-ink">{series.prev.title}</span>
          </a>
        ) : <span />}
        {series.next && (
          <a href={series.next.href} class="rounded-lg border border-line/70 bg-surface/40 p-4 text-right transition-colors hover:border-accent-soft/60 hover:bg-surface">
            <span class="text-xs text-faint">下一篇 →</span>
            <span class="mt-1 block text-sm text-ink">{series.next.title}</span>
          </a>
        )}
      </nav>
    )}
  </main>
</Base>

<style is:global>
  /* Reading surface: generous CJK line-height, restrained rhythm. */
  .article {
    line-height: 1.9;
    font-size: 1.0625rem;
  }
  .article > * + * {
    margin-top: 1.1em;
  }
  .article h2 {
    margin-top: 2.2em;
    font-size: 1.45rem;
    font-weight: 600;
    color: var(--color-chalk);
  }
  .article h3 {
    margin-top: 1.8em;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-chalk);
  }
  .article a {
    color: var(--color-accent-soft); /* Gauss §5.2: accent has 0.21 AA headroom; soft has 5× */
    text-underline-offset: 3px;
    text-decoration: underline;
  }
  .article blockquote {
    border-left: 2px solid var(--color-line);
    padding-left: 1em;
    color: var(--color-muted);
  }
  .article img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    margin-inline: auto;
  }
  .article em:has(+ *) {
    display: block;
  }
  .article figure > em,
  .article img + em {
    display: block;
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-muted);
    font-style: normal;
    margin-top: 0.4em;
  }
  .article pre {
    overflow-x: auto;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    padding: 1em;
    font-size: 0.9rem;
  }
  .article table {
    display: block;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .article td,
  .article th {
    border: 1px solid var(--color-line);
    padding: 0.4em 0.7em;
  }
  .article iframe {
    max-width: 100%;
    display: block;
    margin-inline: auto;
    border: 0;
    aspect-ratio: 16 / 9;
    width: 100%;
    height: auto;
  }
  .article iframe[src*="spotify"] {
    aspect-ratio: auto;
    height: 152px;
  }
  /* Long display equations must scroll inside their own box, never the page. */
  .article .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding-block: 0.2em;
  }
  .article ul,
  .article ol {
    padding-left: 1.4em;
  }
  .article ul {
    list-style: disc;
  }
  .article ol {
    list-style: decimal;
  }
  .article hr {
    border: 0;
    border-top: 1px solid var(--color-line);
    margin-block: 2em;
  }
  /* smooth hand-off when the lightbox pauses/fades the ambient layer */
  :global(.bg-equations) {
    transition: opacity 0.25s ease;
  }
</style>

<script>
  import PhotoSwipe from 'photoswipe';
  import 'photoswipe/style.css';

  // Full viewer per Yeqiu 2026-07-17: click to open, free zoom in/out
  // (wheel / pinch / double-tap), drag to pan, × / Esc to exit.
  // medium-zoom (fixed fit-zoom only) retired.
  const __initOnLoad = () => {
    const article = document.querySelector<HTMLElement>('.article');
    if (!article || article.dataset.zoomWired) return;
    article.dataset.zoomWired = '1';
    const imgs = [...article.querySelectorAll<HTMLImageElement>('img:not(.no-zoom)')];
    if (!imgs.length) return;

    // the ambient equation layer runs SVG turbulence filters continuously —
    // heavy enough to steal frames from the viewer on slower machines
    const ambientSet = (running: boolean) => {
      document.querySelectorAll<HTMLElement>('.bg-equations').forEach((layer) => {
        const svg = layer.querySelector('svg') as SVGSVGElement | null;
        if (running) {
          svg?.unpauseAnimations?.();
          layer.style.opacity = '';
        } else {
          svg?.pauseAnimations?.();
          layer.style.opacity = '0';
        }
      });
    };

    imgs.forEach((img, i) => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        const dataSource = imgs.map((m) => ({
          src: m.currentSrc || m.src,
          width: m.naturalWidth || 1600,
          height: m.naturalHeight || 1200,
          alt: m.alt,
        }));
        const pswp = new PhotoSwipe({
          dataSource,
          index: i,
          wheelToZoom: true,
          // default max zoom = the image's natural size, which leaves small
          // figures with NO zoom range at all — allow magnifying past 1:1
          maxZoomLevel: 4,
          secondaryZoomLevel: 2,
          bgOpacity: 0.95,
          padding: { top: 24, bottom: 24, left: 16, right: 16 },
          closeTitle: '退出',
          zoomTitle: '缩放',
          arrowPrevTitle: '上一张',
          arrowNextTitle: '下一张',
        });
        pswp.on('openingAnimationStart', () => ambientSet(false));
        pswp.on('destroy', () => ambientSet(true));
        pswp.init();
        (window as any).__pswp = pswp; // QA/debug handle

      });
    });
  };
  // register for future swaps AND run now — if this script was swapped in
  // by ClientRouter, this navigation's astro:page-load has already fired
  document.addEventListener('astro:page-load', __initOnLoad);
  __initOnLoad();
</script>
