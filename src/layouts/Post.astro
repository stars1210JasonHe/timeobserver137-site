---
/**
 * Article layout — the quiet reading surface (spec §6: writing pages restrained;
 * cosmos lives in the figures themselves, not behind the text).
 * KaTeX CSS is self-hosted via npm (no CDN); lightbox = medium-zoom on article images.
 */
import 'katex/dist/katex.min.css';
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'zh';
  altHref: string;
  date: Date;
  tags?: string[];
  ogImage?: string;
}
const { title, description, lang, altHref, date, tags = [], ogImage } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
---

<Base {title} {description} {lang} {altHref} {ogImage}>
  <main class="mx-auto max-w-2xl px-6 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-semibold leading-snug text-chalk">{title}</h1>
      <p class="mt-3 flex flex-wrap items-center gap-3 text-sm text-muted">
        <time datetime={dateStr}>{dateStr}</time>
        {tags.map((t) => <span class="rounded border border-line px-1.5 py-0.5 text-xs">{t}</span>)}
      </p>
    </header>
    <article class="article">
      <slot />
    </article>
  </main>
</Base>

<style is:global>
  /* Reading surface: generous CJK line-height, restrained rhythm. */
  .article {
    line-height: 1.9;
    font-size: 1.0625rem;
  }
  .article > * + * {
    margin-top: 1.1em;
  }
  .article h2 {
    margin-top: 2.2em;
    font-size: 1.45rem;
    font-weight: 600;
    color: var(--color-chalk);
  }
  .article h3 {
    margin-top: 1.8em;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-chalk);
  }
  .article a {
    color: var(--color-accent-soft); /* Gauss §5.2: accent has 0.21 AA headroom; soft has 5× */
    text-underline-offset: 3px;
    text-decoration: underline;
  }
  .article blockquote {
    border-left: 2px solid var(--color-line);
    padding-left: 1em;
    color: var(--color-muted);
  }
  .article img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    margin-inline: auto;
  }
  .article em:has(+ *) {
    display: block;
  }
  .article figure > em,
  .article img + em {
    display: block;
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-muted);
    font-style: normal;
    margin-top: 0.4em;
  }
  .article pre {
    overflow-x: auto;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    padding: 1em;
    font-size: 0.9rem;
  }
  .article table {
    display: block;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .article td,
  .article th {
    border: 1px solid var(--color-line);
    padding: 0.4em 0.7em;
  }
  .article iframe {
    max-width: 100%;
    display: block;
    margin-inline: auto;
    border: 0;
    aspect-ratio: 16 / 9;
    width: 100%;
    height: auto;
  }
  .article iframe[src*="spotify"] {
    aspect-ratio: auto;
    height: 152px;
  }
  /* Long display equations must scroll inside their own box, never the page. */
  .article .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding-block: 0.2em;
  }
  .article ul,
  .article ol {
    padding-left: 1.4em;
  }
  .article ul {
    list-style: disc;
  }
  .article ol {
    list-style: decimal;
  }
  .article hr {
    border: 0;
    border-top: 1px solid var(--color-line);
    margin-block: 2em;
  }
</style>

<script>
  import mediumZoom from 'medium-zoom';
  mediumZoom('.article img:not(.no-zoom)', {
    background: 'rgba(6, 8, 12, 0.94)',
    margin: 24,
  });
</script>
