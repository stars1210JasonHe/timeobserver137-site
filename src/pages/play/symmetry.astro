>
  <main>
    <SymmetryPuzzle lang="en" />
    <p class="mx-auto max-w-3xl px-6 pb-16 text-sm text-muted">
      <a class="text-accent-soft underline underline-offset-2" href="/play/">← More games</a>
    </p>
  </main>
</Base>
