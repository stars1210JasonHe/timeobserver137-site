---
/**
 * Game hub — /play/: one card per game (2026-07-17).
 */
import Base from '../../layouts/Base.astro';

const GAMES = [
  {
    href: '/play/one-stroke/',
    icon: '✒️',
    title: 'One Stroke',
    desc: '10 levels: draw the drawable, call out the impossible. The walkthrough is Euler’s 1736 criterion.',
  },
  {
    href: '/play/symmetry/',
    icon: '❖',
    title: 'Symmetry Puzzle',
    desc: '10 levels: solve the solvable, see through the impossible — the square’s 8 symmetries are the group D₄.',
  },
  {
    href: '/play/rubiks/',
    icon: '🧊',
    title: "Rubik's Cube (3D)",
    desc: 'Drag to orbit, buttons to turn layers. 43 quintillion states, never more than 20 moves from solved.',
  },
];
---

<Base
  title="Play — 时间观察者"
  description="Game hub: One Stroke, Symmetry Puzzle and a 3D Rubik's cube — each with a piece of mathematics inside."
  lang="en"
  altHref="/zh/play/"
>
  <main class="mx-auto max-w-3xl px-6 py-12">
    <p class="text-sm uppercase tracking-[0.25em] text-muted">Arcade</p>
    <h1 class="mt-3 text-3xl font-semibold text-chalk">Play</h1>
    <p class="mt-3 leading-relaxed text-muted">Each game hides a piece of mathematics — beat the game, and the mathematics is yours.</p>
    <div class="mt-8 grid gap-5 sm:grid-cols-2">
      {
        GAMES.map((g) => (
          <a href={g.href} class="block rounded-lg border border-line/70 bg-surface/40 p-6 transition-colors hover:border-accent-soft/60 hover:bg-surface">
            <p class="text-2xl">{g.icon}</p>
            <p class="mt-2 text-lg font-semibold text-chalk">{g.title}</p>
            <p class="mt-2 text-sm leading-relaxed text-muted">{g.desc}</p>
          </a>
        ))
      }
      <a href="https://meinopoly.pages.dev" class="block rounded-lg border border-line/70 bg-surface/40 p-6 transition-colors hover:border-accent-soft/60 hover:bg-surface">
        <p class="text-2xl">🎲</p>
        <p class="mt-2 text-lg font-semibold text-chalk">Meinopoly <span class="text-sm text-faint">↗</span></p>
        <p class="mt-2 text-sm leading-relaxed text-muted">Turn any book into a board game — a moddable strategy engine, solo with local bots, right in the browser.</p>
      </a>
    </div>
  </main>
</Base>
