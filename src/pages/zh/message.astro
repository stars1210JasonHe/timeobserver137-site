---
/**
 * 留言 — private message box (2026-07-18, Yeqiu: 只给你看,不公开).
 * Nothing submitted here is ever rendered on the site; a Pi cron pushes new
 * messages to Yeqiu's Telegram.
 */
import Base from '../../layouts/Base.astro';
---

<Base
  title="留言 — 时间观察者"
  description="给我留言 —— 一个私密信箱,只有我能看到,不会公开显示。"
  lang="zh"
  altHref="/message/"
>
  <main class="mx-auto max-w-2xl px-6 py-12">
    <h1 class="text-3xl font-semibold text-chalk">留言</h1>
    <p class="mt-4 leading-relaxed text-muted">
      有什么想说的,都可以写在这里 —— 读后感、指正、想看的选题,或者只是打个招呼。
    </p>
    <p class="mt-3 leading-relaxed text-muted">
      这是一个<strong class="text-ink">私密信箱</strong>:留言不会显示在网站上,只有我能看到。留了邮箱的话,我可能会回你。
    </p>

    <form id="msg-form" class="mt-8 space-y-4">
      <div>
        <label class="block text-sm text-ink" for="m-name">怎么称呼你 <span class="text-accent-soft">*</span></label>
        <input
          id="m-name"
          name="name"
          required
          maxlength="60"
          class="mt-1 w-full rounded-md border border-line bg-surface/60 px-3 py-2 text-ink outline-none transition-colors focus:border-accent-soft"
        />
      </div>
      <div>
        <label class="block text-sm text-ink" for="m-email">邮箱 <span class="text-faint">(选填,想要回复就留)</span></label>
        <input
          id="m-email"
          name="email"
          type="email"
          maxlength="254"
          class="mt-1 w-full rounded-md border border-line bg-surface/60 px-3 py-2 text-ink outline-none transition-colors focus:border-accent-soft"
        />
      </div>
      <div>
        <label class="block text-sm text-ink" for="m-body">留言 <span class="text-accent-soft">*</span></label>
        <textarea
          id="m-body"
          name="body"
          required
          rows="7"
          maxlength="4000"
          class="mt-1 w-full rounded-md border border-line bg-surface/60 px-3 py-2 leading-relaxed text-ink outline-none transition-colors focus:border-accent-soft"
        ></textarea>
      </div>
      <!-- honeypot: hidden from humans, bots fill it -->
      <div class="hidden" aria-hidden="true">
        <label for="m-website">Website</label>
        <input id="m-website" name="website" tabindex="-1" autocomplete="off" />
      </div>
      <button
        type="submit"
        class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-soft"
        >寄出</button
      >
    </form>
    <p id="msg-status" class="mt-4 hidden text-sm"></p>
  </main>
</Base>

<script>
  const __initOnLoad = () => {
    const form = document.getElementById('msg-form') as HTMLFormElement | null;
    const status = document.getElementById('msg-status');
    if (!form || !status || form.dataset.wired) return;
    form.dataset.wired = '1';
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
      btn.disabled = true;
      status.classList.remove('hidden');
      status.className = 'mt-4 text-sm text-muted';
      status.textContent = '寄送中……';
      try {
        const res = await fetch('/api/message', { method: 'POST', body: new URLSearchParams(new FormData(form) as any) });
        const data = await res.json();
        if (data.ok) {
          status.className = 'mt-4 text-sm text-accent-soft';
          status.textContent = '收到了,谢谢你 —— 我会读的。';
          form.reset();
        } else {
          status.className = 'mt-4 text-sm text-red-400';
          status.textContent = data.error === 'daily limit' ? '今天留言有点多啦,明天再来?' : '出了点问题,过会儿再试试。';
        }
      } catch {
        status.className = 'mt-4 text-sm text-red-400';
        status.textContent = '网络不太好,过会儿再试试。';
      }
      btn.disabled = false;
    });
  };
  // register for future swaps AND run now — if this script was swapped in
  // by ClientRouter, this navigation's astro:page-load has already fired
  document.addEventListener('astro:page-load', __initOnLoad);
  __initOnLoad();
</script>
