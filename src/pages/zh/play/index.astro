---
/**
 * 游戏厅 — /zh/play/: grows one card per game (2026-07-17 Yeqiu:
 * one-stroke + symmetry + 3D cube; Meinopoly external).
 */
import Base from '../../../layouts/Base.astro';

const GAMES = [
  {
    href: '/zh/play/one-stroke/',
    icon: '✒️',
    title: '一笔画',
    desc: '10 关:可解的画出来,无解的认出来。通关秘籍是欧拉 1736 年的判据。',
  },
  {
    href: '/zh/play/symmetry/',
    icon: '❖',
    title: '对称拼图',
    desc: '用旋转和翻转把图案变成目标 —— 正方形的 8 种对称,就是群 D₄。',
  },
  {
    href: '/zh/play/rubiks/',
    icon: '🧊',
    title: '魔方(3D)',
    desc: '拖动旋转视角,按钮转层。4300 亿亿种状态,离还原永远不超过 20 步。',
  },
];
---

<Base
  title="小游戏 — 时间观察者"
  description="游戏厅:一笔画、对称拼图、3D 魔方 —— 每个游戏背后都藏着一段数学。"
  lang="zh"
  altHref="/play/"
>
  <main class="mx-auto max-w-3xl px-6 py-12">
    <p class="text-sm uppercase tracking-[0.25em] text-muted">游戏厅</p>
    <h1 class="mt-3 text-3xl font-semibold text-chalk">小游戏</h1>
    <p class="mt-3 leading-relaxed text-muted">每个游戏背后都藏着一段数学 —— 玩通了,那段数学也就懂了。</p>
    <div class="mt-8 grid gap-5 sm:grid-cols-2">
      {
        GAMES.map((g) => (
          <a href={g.href} class="block rounded-lg border border-line/70 bg-surface/40 p-6 transition-colors hover:border-accent-soft/60 hover:bg-surface">
            <p class="text-2xl">{g.icon}</p>
            <p class="mt-2 text-lg font-semibold text-chalk">{g.title}</p>
            <p class="mt-2 text-sm leading-relaxed text-muted">{g.desc}</p>
          </a>
        ))
      }
      <a href="https://meinopoly.pages.dev" class="block rounded-lg border border-line/70 bg-surface/40 p-6 transition-colors hover:border-accent-soft/60 hover:bg-surface">
        <p class="text-2xl">🎲</p>
        <p class="mt-2 text-lg font-semibold text-chalk">Meinopoly <span class="text-sm text-faint">↗</span></p>
        <p class="mt-2 text-sm leading-relaxed text-muted">把任何一本书变成大富翁 —— 可改装的策略引擎,单机 + 本地人机,浏览器直接玩。</p>
      </a>
    </div>
  </main>
</Base>
