---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', (e) => e.data.lang === 'zh');
  return projects.map((entry) => ({
    params: { slug: entry.id.split('/').pop()!.replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const slug = entry.id.split('/').pop()!.replace(/\.mdx?$/, '');
---

<Base title={`${d.title} — 贺冶秋`} description={d.tagline} lang="zh" altHref={`/projects/${slug}/`} ogImage={d.cover}>
  <main class="mx-auto max-w-2xl px-6 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-semibold leading-snug text-chalk">{d.title}</h1>
      <p class="mt-3 text-lg text-muted">{d.tagline}</p>
      <p class="mt-4 flex flex-wrap gap-2">
        {d.stack.map((s) => <span class="rounded bg-surface-2 px-2 py-0.5 text-xs text-faint">{s}</span>)}
      </p>
      <p class="mt-4 flex gap-4 text-sm">
        {d.links.live && <a class="text-accent-soft underline underline-offset-2" href={d.links.live}>线上</a>}
        {d.links.github && <a class="text-accent-soft underline underline-offset-2" href={d.links.github}>GitHub</a>}
      </p>
    </header>
    <article class="article">
      <Content />
    </article>
  </main>
</Base>

<style is:global>
  .article {
    line-height: 1.9;
  }
  .article > * + * {
    margin-top: 1em;
  }
  .article h2 {
    margin-top: 2em;
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-chalk);
  }
  .article ul {
    list-style: disc;
    padding-left: 1.4em;
  }
  .article a {
    color: var(--color-accent-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article strong {
    color: var(--color-chalk);
  }
</style>
