---
/**
 * Series page — /zh/series/<id>/: intro + ordered episode list.
 */
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { SERIES } from '../../../data/series';
import { postSlug } from '../../../data/slug';

export async function getStaticPaths() {
  const posts = await getCollection('writing', (e) => e.data.lang === 'zh' && !e.data.draft && e.data.series);
  return SERIES.map((s) => ({
    params: { id: s.id },
    props: {
      meta: s,
      eps: posts
        .filter((p) => p.data.series === s.id)
        .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0)),
    },
  }));
}

const { meta, eps } = Astro.props;
---

<Base title={`${meta.title} — 系列 — 时间观察者`} description={meta.description} lang="zh" altHref="/zh/writing/">
  <main class="mx-auto max-w-2xl px-6 py-12">
    <p class="text-sm text-muted"><a href="/zh/series/" class="hover:text-ink">系列</a></p>
    <h1 class="mt-2 text-3xl font-semibold text-chalk">{meta.title}</h1>
    <p class="mt-3 flex items-center gap-3">
      <span class:list={['rounded border px-1.5 py-0.5 text-xs', meta.status === '连载中' ? 'border-accent-soft/60 text-accent-soft' : 'border-line text-muted']}>{meta.status}</span>
      <span class="text-sm text-muted">{eps.length} 篇</span>
    </p>
    <p class="mt-4 leading-relaxed text-muted">{meta.description}</p>
    {meta.note && <p class="mt-2 text-sm text-faint">{meta.note}</p>}
    <ol class="mt-8 space-y-3">
      {
        eps.map((e) => (
          <li>
            <a href={`/zh/writing/${postSlug(e)}/`} class="group flex items-baseline gap-4 rounded-lg border border-line/70 bg-surface/40 p-4 transition-colors hover:border-accent-soft/60 hover:bg-surface">
              <span class="shrink-0 font-mono text-sm text-faint">{String(e.data.seriesOrder).padStart(2, '0')}</span>
              <span class="flex-1">
                <span class="font-medium text-ink group-hover:text-chalk">{e.data.title}</span>
                <time class="mt-1 block text-xs text-faint" datetime={e.data.date.toISOString().slice(0, 10)}>{e.data.date.toISOString().slice(0, 10)}</time>
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </main>
</Base>
