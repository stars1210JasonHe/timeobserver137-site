---
import { getCollection, render } from 'astro:content';
import Post from '../../../layouts/Post.astro';
import { seriesById } from '../../../data/series';
import { postSlug } from '../../../data/slug';

export async function getStaticPaths() {
  const posts = await getCollection('writing', (e) => e.data.lang === 'zh');
  return posts.map((entry) => ({
    params: { slug: postSlug(entry) },
    props: { entry, all: posts },
  }));
}

const { entry, all } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

// series context: breadcrumb + prev/next episode
let seriesCtx = null;
if (d.series) {
  const meta = seriesById(d.series);
  const eps = all
    .filter((p) => p.data.series === d.series && !p.data.draft)
    .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
  const idx = eps.findIndex((p) => p.id === entry.id);
  const link = (p) => `/zh/writing/${postSlug(p)}/`;
  seriesCtx = meta && {
    id: d.series,
    title: meta.title,
    order: d.seriesOrder,
    total: eps.length,
    prev: idx > 0 ? { title: eps[idx - 1].data.title, href: link(eps[idx - 1]) } : null,
    next: idx >= 0 && idx < eps.length - 1 ? { title: eps[idx + 1].data.title, href: link(eps[idx + 1]) } : null,
  };
}
---

<Post
  title={d.title}
  description={d.excerpt ?? `${d.title} — 时间观察者`}
  lang="zh"
  altHref="/writing/"
  date={d.date}
  tags={d.tags}
  ogImage={d.cover}
  series={seriesCtx}
>
  <Content />
</Post>
