---
import Base from '../layouts/Base.astro';
---

<Base
  title="Resume — Yeqiu He"
  description="Resume of Yeqiu He — AI Systems Engineer."
  lang="en"
  altHref="/zh/"
>
  <main class="mx-auto max-w-2xl px-6 py-12">
    <h1 class="text-3xl font-semibold text-chalk">Resume</h1>
    <p class="mt-6 leading-relaxed text-ink">
      <strong class="text-chalk">Yeqiu He</strong> — AI Systems Engineer. Multi-agent systems,
      retrieval pipelines, full-stack builds. Theoretical physics background.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/resume/Yeqiu_He_Resume_AU.pdf"
        class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-soft"
        >Download PDF</a
      >
      <a
        href="/projects/"
        class="rounded-md border border-line px-4 py-2 text-sm text-ink transition-colors hover:border-accent-soft"
        >See the work</a
      >
    </div>
    <p class="mt-10 text-sm text-muted">
      Highlights: an <a class="text-accent-soft underline underline-offset-2" href="/projects/openclaw-fleet/">eight-agent fleet</a>
      with a versioned memory architecture · a <a class="text-accent-soft underline underline-offset-2" href="/projects/meinrag/">multimodal RAG platform</a>
      in daily production · <a class="text-accent-soft underline underline-offset-2" href="/writing/">long-form technical writing</a>.
    </p>
  </main>
</Base>
