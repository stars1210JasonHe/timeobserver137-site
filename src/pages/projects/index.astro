---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects', (e) => e.data.lang === 'en')).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured) || a.data.order - b.data.order,
);
---

<Base
  title="Projects — Yeqiu He"
  description="Multi-agent systems, RAG pipelines, and full-stack builds by Yeqiu He."
  lang="en"
  altHref="/zh/projects/"
>
  <main class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="mb-2 text-3xl font-semibold text-chalk">Projects</h1>
    <p class="mb-8 text-sm text-muted">Systems I've built and operate — agents, retrieval, and the occasional game board.</p>
    <div class="grid gap-4 sm:grid-cols-2">
      {projects.map((p) => (
        <ProjectCard
          href={`/projects/${p.id.split('/').pop()!.replace(/\.mdx?$/, '')}/`}
          title={p.data.title}
          tagline={p.data.tagline}
          stack={p.data.stack}
          featured={p.data.featured}
        />
      ))}
    </div>
  </main>
</Base>
