---
/**
 * Message — private message box (EN counterpart of /zh/message/).
 * Nothing submitted here is ever rendered on the site.
 */
import Base from '../layouts/Base.astro';
---

<Base
  title="Message — 时间观察者"
  description="Leave me a message — a private inbox. Nothing here is shown publicly."
  lang="en"
  altHref="/zh/message/"
>
  <main class="mx-auto max-w-2xl px-6 py-12">
    <h1 class="text-3xl font-semibold text-chalk">Message</h1>
    <p class="mt-4 leading-relaxed text-muted">
      Anything you'd like to say — thoughts on a piece, a correction, a topic you'd like to see, or
      just hello.
    </p>
    <p class="mt-3 leading-relaxed text-muted">
      This is a <strong class="text-ink">private inbox</strong>: messages are never shown on the
      site, only I can read them. Leave an email and I may write back.
    </p>

    <form id="msg-form" class="mt-8 space-y-4">
      <div>
        <label class="block text-sm text-ink" for="m-name">Your name <span class="text-accent-soft">*</span></label>
        <input
          id="m-name"
          name="name"
          required
          maxlength="60"
          class="mt-1 w-full rounded-md border border-line bg-surface/60 px-3 py-2 text-ink outline-none transition-colors focus:border-accent-soft"
        />
      </div>
      <div>
        <label class="block text-sm text-ink" for="m-email">Email <span class="text-faint">(optional, if you'd like a reply)</span></label>
        <input
          id="m-email"
          name="email"
          type="email"
          maxlength="254"
          class="mt-1 w-full rounded-md border border-line bg-surface/60 px-3 py-2 text-ink outline-none transition-colors focus:border-accent-soft"
        />
      </div>
      <div>
        <label class="block text-sm text-ink" for="m-body">Message <span class="text-accent-soft">*</span></label>
        <textarea
          id="m-body"
          name="body"
          required
          rows="7"
          maxlength="4000"
          class="mt-1 w-full rounded-md border border-line bg-surface/60 px-3 py-2 leading-relaxed text-ink outline-none transition-colors focus:border-accent-soft"
        ></textarea>
      </div>
      <!-- honeypot: hidden from humans, bots fill it -->
      <div class="hidden" aria-hidden="true">
        <label for="m-website">Website</label>
        <input id="m-website" name="website" tabindex="-1" autocomplete="off" />
      </div>
      <button
        type="submit"
        class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-soft"
        >Send</button
      >
    </form>
    <p id="msg-status" class="mt-4 hidden text-sm"></p>
  </main>
</Base>

<script>
  const __initOnLoad = () => {
    const form = document.getElementById('msg-form') as HTMLFormElement | null;
    const status = document.getElementById('msg-status');
    if (!form || !status || form.dataset.wired) return;
    form.dataset.wired = '1';
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
      btn.disabled = true;
      status.classList.remove('hidden');
      status.className = 'mt-4 text-sm text-muted';
      status.textContent = 'Sending…';
      try {
        const res = await fetch('/api/message', { method: 'POST', body: new URLSearchParams(new FormData(form) as any) });
        const data = await res.json();
        if (data.ok) {
          status.className = 'mt-4 text-sm text-accent-soft';
          status.textContent = 'Got it — thank you. I read every one.';
          form.reset();
        } else {
          status.className = 'mt-4 text-sm text-red-400';
          status.textContent = data.error === 'daily limit' ? "That's a lot of messages today — try again tomorrow?" : 'Something went wrong, please try again later.';
        }
      } catch {
        status.className = 'mt-4 text-sm text-red-400';
        status.textContent = 'Network hiccup — please try again later.';
      }
      btn.disabled = false;
    });
  };
  // register for future swaps AND run now — if this script was swapped in
  // by ClientRouter, this navigation's astro:page-load has already fired
  document.addEventListener('astro:page-load', __initOnLoad);
  __initOnLoad();
</script>
