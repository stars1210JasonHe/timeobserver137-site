---
/**
 * BackgroundEquations — the four equations as COSMIC background.
 *
 * v4 (Yeqiu 2026-07-17): each equation's click-burst enacts ITS OWN physics:
 *   Noether   → a symmetry operation (full rotation) around an unmoving
 *               conservation ring — the thing that stays fixed IS the point;
 *   Path int. → sum over histories: ghost copies fan out along different
 *               paths and interfere back into one;
 *   Dirac     → pair creation: a colour-inverted anti-equation splits off,
 *               returns, annihilates in a flash;
 *   EFE       → spacetime quake + expanding gravitational-wave rings.
 * Ambient motion stays SMIL-driven (Chrome repaint reliability, v3 lesson);
 * hover still freezes a single equation (per-svg pauseAnimations).
 *
 * variant="ambient" (article pages): non-interactive, quieter, fixed — the
 * cosmos sits behind long reads without inviting play (研究 §3.1: 长读面安静).
 */
import katex from 'katex';
import 'katex/dist/katex.min.css';

interface Props {
  variant?: 'hero' | 'ambient';
}
const { variant = 'hero' } = Astro.props;

const eqs = [
  { tex: String.raw`\frac{d}{dt}\!\left(\frac{\partial L}{\partial \dot q}\,\delta q\right)=0`, cls: 'eq-noether' },
  { tex: String.raw`\langle x_f|e^{-iHt/\hbar}|x_i\rangle=\int\!\mathcal{D}[x(t)]\,e^{iS[x]/\hbar}`, cls: 'eq-path' },
  { tex: String.raw`(i\gamma^\mu\partial_\mu-m)\,\psi=0`, cls: 'eq-dirac' },
  { tex: String.raw`G_{\mu\nu}+\Lambda g_{\mu\nu}=\frac{8\pi G}{c^4}T_{\mu\nu}`, cls: 'eq-efe' },
].map((e, i) => ({ ...e, i, html: katex.renderToString(e.tex, { throwOnError: false, output: 'html' }) }));

const uid = variant; // ids must differ if both variants ever co-exist on a page
---

<div class:list={['bg-equations', variant, 'pointer-events-none', variant === 'hero' ? 'absolute' : 'fixed', 'inset-0', 'overflow-hidden']} aria-hidden="true">
  {
    eqs.map((e) => (
      <div class:list={['bg-eq', e.cls]} data-eq={e.i}>
        <svg width="0" height="0" class="eq-filter-host" aria-hidden="true">
          <filter id={`eq-warp-${uid}-${e.i}`} x="-25%" y="-60%" width="150%" height="220%">
            <feTurbulence type="fractalNoise" baseFrequency="0.014 0.026" numOctaves="2" seed={e.i * 7 + 1}>
              <animate
                attributeName="baseFrequency"
                dur={`${5.5 + e.i * 1.3}s`}
                values="0.014 0.026;0.026 0.05;0.014 0.026"
                repeatCount="indefinite"
              />
            </feTurbulence>
            <feDisplacementMap in="SourceGraphic" scale="12" xChannelSelector="R" yChannelSelector="G">
              <animate attributeName="scale" dur={`${4 + e.i}s`} values="9;16;9" repeatCount="indefinite" />
              <animate class="eq-quake" attributeName="scale" dur="0.9s" values="12;46;6;12" begin="indefinite" />
            </feDisplacementMap>
          </filter>
        </svg>
        <span class="eq-text" style={`filter:url(#eq-warp-${uid}-${e.i})`} set:html={e.html} />
      </div>
    ))
  }
</div>

<script>
  function initEquations() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    for (const root of document.querySelectorAll<HTMLElement>('.bg-equations')) {
      if (root.dataset.eqInit) continue;
      root.dataset.eqInit = '1';
      const interactive = root.classList.contains('hero');
      const wraps = [...root.querySelectorAll<HTMLElement>('.bg-eq')];

      for (const el of wraps) {
        const svg = el.querySelector('svg') as SVGSVGElement | null;
        const text = el.querySelector<HTMLElement>('.eq-text');
        if (!svg || !text) continue;
        if (reduced) {
          svg.pauseAnimations();
          text.style.filter = 'none';
          continue;
        }
        if (!interactive) continue;

        // hover keeps the shimmer running and warms it up (Yeqiu 2026-07-17:
        // 悬停让动画继续 — the freeze is gone; reduced-motion remains the stop).
        el.addEventListener('pointerenter', () => el.classList.add('eq-hot'));
        el.addEventListener('pointerleave', () => el.classList.remove('eq-hot'));
        el.addEventListener('click', () => burst(Number(el.dataset.eq), el, svg, text));
      }

      // park shimmer while the host section is off-screen (WebKit guidance)
      const anchorEl = interactive ? document.querySelector('.hero') : root;
      if (anchorEl && !reduced) {
        new IntersectionObserver(([e]) => {
          for (const el of wraps) {
            const svg = el.querySelector('svg') as SVGSVGElement | null;
            svg && (e.isIntersecting ? svg.unpauseAnimations() : svg.pauseAnimations());
          }
        }).observe(anchorEl);
      }
    }
  }

  function ring(el: HTMLElement, delay = 0, size = '34rem') {
    const r = document.createElement('span');
    r.className = 'eq-ring';
    r.style.width = size;
    r.style.height = size;
    el.appendChild(r);
    r.animate(
      [
        { transform: 'translate(-50%,-50%) scale(0.15)', opacity: 0.55 },
        { transform: 'translate(-50%,-50%) scale(1)', opacity: 0 },
      ],
      { duration: 1100, delay, easing: 'cubic-bezier(0.2,0.6,0.3,1)', fill: 'forwards' },
    ).finished.then(() => r.remove());
  }

  function flare(text: HTMLElement, peak = 2.4, dur = 900) {
    text.animate(
      [{ filter: 'brightness(1)' }, { filter: `brightness(${peak})`, offset: 0.18 }, { filter: 'brightness(1)' }],
      { duration: dur, easing: 'ease-out' },
    );
  }

  function ghost(text: HTMLElement): HTMLElement {
    const g = text.cloneNode(true) as HTMLElement;
    g.style.position = 'absolute';
    g.style.left = '0';
    g.style.top = '0';
    g.style.pointerEvents = 'none';
    text.parentElement!.appendChild(g);
    return g;
  }

  function burst(i: number, el: HTMLElement, svg: SVGSVGElement, text: HTMLElement) {
    svg.unpauseAnimations();
    if (i === 0) {
      // NOETHER — perform the symmetry operation; the conservation ring holds still.
      const r = document.createElement('span');
      r.className = 'eq-ring eq-ring-conserved';
      el.appendChild(r);
      r.animate([{ opacity: 0 }, { opacity: 0.5, offset: 0.2 }, { opacity: 0.5, offset: 0.8 }, { opacity: 0 }], {
        duration: 1400,
        easing: 'ease-in-out',
      }).finished.then(() => r.remove());
      text.animate(
        [
          { transform: 'rotate(0deg) scale(1)' },
          { transform: 'rotate(180deg) scale(0.92)', offset: 0.5 },
          { transform: 'rotate(360deg) scale(1)' },
        ],
        { duration: 1300, easing: 'cubic-bezier(0.5,0,0.3,1)' },
      );
      flare(text, 1.8, 1300);
    } else if (i === 1) {
      // PATH INTEGRAL — every history contributes: ghosts fan out, interfere back.
      const paths = [
        { x: -70, y: -46, rot: -10 },
        { x: 60, y: -60, rot: 8 },
        { x: -50, y: 55, rot: 6 },
        { x: 75, y: 40, rot: -7 },
      ];
      for (const pth of paths) {
        const g = ghost(text);
        g.animate(
          [
            { transform: 'translate(0,0) rotate(0deg)', opacity: 0.5 },
            { transform: `translate(${pth.x}px,${pth.y}px) rotate(${pth.rot}deg)`, opacity: 0.28, offset: 0.45 },
            { transform: 'translate(0,0) rotate(0deg)', opacity: 0 },
          ],
          { duration: 1250, easing: 'cubic-bezier(0.4,0,0.4,1)' },
        ).finished.then(() => g.remove());
      }
      flare(text, 2.0, 1250);
    } else if (i === 2) {
      // DIRAC — pair creation: the anti-equation splits off, returns, annihilates.
      const anti = ghost(text);
      anti.style.filter = 'invert(1) hue-rotate(180deg)';
      anti.animate(
        [
          { transform: 'translate(0,0) scaleX(1)', opacity: 0.7 },
          { transform: 'translate(90px,-34px) scaleX(-1)', opacity: 0.55, offset: 0.45 },
          { transform: 'translate(0,0) scaleX(-1)', opacity: 0.9, offset: 0.85 },
          { transform: 'translate(0,0) scaleX(1)', opacity: 0 },
        ],
        { duration: 1200, easing: 'cubic-bezier(0.45,0,0.4,1)' },
      ).finished.then(() => {
        anti.remove();
        flare(text, 3, 500); // annihilation flash
        ring(el, 0, '16rem');
      });
    } else {
      // EFE — spacetime quake + gravitational waves.
      (svg.querySelector('.eq-quake') as any)?.beginElement?.();
      flare(text);
      ring(el, 0);
      ring(el, 180);
    }
  }

  document.addEventListener('astro:page-load', initEquations);
  initEquations();
</script>

<style>
  .bg-eq {
    position: absolute;
    user-select: none;
    animation: eq-emerge 1.8s ease forwards;
    opacity: 0;
  }
  .bg-equations.hero .bg-eq {
    pointer-events: auto; /* hover-glow + click-burst need hit-testing */
    cursor: pointer;
    transition: opacity 0.35s ease;
  }
  .bg-equations.hero .bg-eq.eq-hot {
    opacity: 0.55 !important;
  }
  .bg-eq.eq-hot .eq-text {
    text-shadow:
      0 0 26px color-mix(in srgb, var(--color-accent) 90%, transparent),
      0 0 6px rgba(230, 238, 255, 0.9);
  }
  :global(.eq-ring) {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 34rem;
    height: 34rem;
    border-radius: 9999px;
    border: 1.5px solid color-mix(in srgb, var(--color-accent-soft) 70%, transparent);
    box-shadow:
      0 0 24px color-mix(in srgb, var(--color-accent) 45%, transparent),
      inset 0 0 18px color-mix(in srgb, var(--color-accent) 30%, transparent);
    pointer-events: none;
    transform: translate(-50%, -50%) scale(0.15);
    opacity: 0;
  }
  :global(.eq-ring-conserved) {
    width: 15rem;
    height: 15rem;
    transform: translate(-50%, -50%);
    border-color: color-mix(in srgb, var(--color-gold) 75%, transparent);
    box-shadow: 0 0 20px color-mix(in srgb, var(--color-gold) 40%, transparent);
  }
  .eq-text {
    display: inline-block;
    color: color-mix(in srgb, var(--color-accent-soft) 55%, #e6eeff);
    text-shadow:
      0 0 18px color-mix(in srgb, var(--color-accent) 70%, transparent),
      0 0 4px rgba(230, 238, 255, 0.7);
  }
  html[data-theme='light'] .eq-text {
    color: color-mix(in srgb, var(--color-accent) 70%, #16203a);
    text-shadow: 0 0 12px color-mix(in srgb, var(--color-accent) 35%, transparent);
  }
  @keyframes eq-emerge {
    to {
      opacity: 0.34;
    }
  }
  html[data-theme='light'] .bg-eq {
    animation-name: eq-emerge-light;
  }
  @keyframes eq-emerge-light {
    to {
      opacity: 0.22;
    }
  }
  /* ambient variant (article pages): quieter, further back */
  .bg-equations.ambient {
    z-index: -1;
  }
  .bg-equations.ambient .bg-eq {
    animation-name: eq-emerge-ambient;
  }
  @keyframes eq-emerge-ambient {
    to {
      opacity: 0.13;
    }
  }
  html[data-theme='light'] .bg-equations.ambient .bg-eq {
    animation-name: eq-emerge-ambient-light;
  }
  @keyframes eq-emerge-ambient-light {
    to {
      opacity: 0.09;
    }
  }
  .eq-noether {
    top: 6%;
    left: 3%;
    font-size: 1.35rem;
    transform: rotate(-4deg);
    animation-delay: 0.2s;
  }
  .eq-path {
    bottom: 9%;
    right: 2%;
    font-size: 1.5rem;
    transform: rotate(2.5deg);
    animation-delay: 1.1s;
  }
  .eq-dirac {
    bottom: 21%;
    left: 8%;
    font-size: 1.25rem;
    transform: rotate(3deg);
    animation-delay: 0.65s;
  }
  .eq-efe {
    top: 11%;
    right: 6%;
    font-size: 1.4rem;
    transform: rotate(-2deg);
    animation-delay: 1.55s;
  }
  .bg-equations.ambient .eq-noether {
    top: 12%;
  }
  .bg-equations.ambient .eq-dirac {
    bottom: 12%;
  }
  @media (prefers-reduced-motion: reduce) {
    .bg-eq {
      animation: none;
      opacity: 0.28;
    }
    .bg-equations.ambient .bg-eq {
      opacity: 0.1;
    }
  }
  @media (max-width: 1024px) {
    .eq-path,
    .eq-efe {
      display: none;
    }
    .bg-eq {
      font-size: 1rem;
    }
  }
</style>
