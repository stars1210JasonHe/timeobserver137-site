---
/**
 * BackgroundEquations — the four equations as COSMIC background.
 * v3 (Yeqiu: 「没动，也看不太清」): SMIL-driven turbulence — Chrome does not
 * reliably repaint an HTML element when JS mutates its SVG filter's internals
 * (v2 verified the *attribute* changed, not the *pixels*; classic
 * measured-one-field-vouched-for-another). SMIL animation of feTurbulence /
 * feDisplacementMap is invalidated natively by the browser. Each equation
 * carries its own tiny <svg> so pauseAnimations() can freeze ONE equation on
 * hover. Visibility raised (opacity/glow/scale).
 */
import katex from 'katex';
import 'katex/dist/katex.min.css';

const eqs = [
  { tex: String.raw`\frac{d}{dt}\!\left(\frac{\partial L}{\partial \dot q}\,\delta q\right)=0`, cls: 'eq-noether' },
  { tex: String.raw`\langle x_f|e^{-iHt/\hbar}|x_i\rangle=\int\!\mathcal{D}[x(t)]\,e^{iS[x]/\hbar}`, cls: 'eq-path' },
  { tex: String.raw`(i\gamma^\mu\partial_\mu-m)\,\psi=0`, cls: 'eq-dirac' },
  { tex: String.raw`G_{\mu\nu}+\Lambda g_{\mu\nu}=\frac{8\pi G}{c^4}T_{\mu\nu}`, cls: 'eq-efe' },
].map((e, i) => ({ ...e, i, html: katex.renderToString(e.tex, { throwOnError: false, output: 'html' }) }));
---

<div class="bg-equations pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  {
    eqs.map((e) => (
      <div class:list={['bg-eq', e.cls]} data-eq={e.i}>
        <svg width="0" height="0" class="eq-filter-host" aria-hidden="true">
          <filter id={`eq-warp-${e.i}`} x="-25%" y="-60%" width="150%" height="220%">
            <feTurbulence type="fractalNoise" baseFrequency="0.014 0.026" numOctaves="2" seed={e.i * 7 + 1}>
              <animate
                attributeName="baseFrequency"
                dur={`${5.5 + e.i * 1.3}s`}
                values="0.014 0.026;0.026 0.05;0.014 0.026"
                repeatCount="indefinite"
              />
            </feTurbulence>
            <feDisplacementMap in="SourceGraphic" scale="12" xChannelSelector="R" yChannelSelector="G">
              <animate attributeName="scale" dur={`${4 + e.i}s`} values="9;16;9" repeatCount="indefinite" />
              <animate class="eq-quake" attributeName="scale" dur="0.9s" values="12;46;6;12" begin="indefinite" />
            </feDisplacementMap>
          </filter>
        </svg>
        <span class="eq-text" style={`filter:url(#eq-warp-${e.i})`} set:html={e.html} />
      </div>
    ))
  }
</div>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const wraps = [...document.querySelectorAll<HTMLElement>('.bg-eq')];
  for (const el of wraps) {
    const svg = el.querySelector('svg') as SVGSVGElement | null;
    const text = el.querySelector<HTMLElement>('.eq-text');
    if (!svg || !text) continue;
    if (reduced) {
      svg.pauseAnimations();
      text.style.filter = 'none';
      continue;
    }
    // hover freezes THIS equation only (2.2.2 stop mechanism, per-element)
    el.addEventListener('pointerenter', () => svg.pauseAnimations());
    el.addEventListener('pointerleave', () => svg.unpauseAnimations());

    // click = gravitational-wave burst: quake spike + expanding rings + flare
    el.addEventListener('click', () => {
      svg.unpauseAnimations(); // a quake needs live spacetime even mid-hover
      (svg.querySelector('.eq-quake') as any)?.beginElement?.();
      text.animate(
        [
          { filter: 'brightness(1)', opacity: 1 },
          { filter: 'brightness(2.4)', opacity: 1, offset: 0.18 },
          { filter: 'brightness(1)', opacity: 1 },
        ],
        { duration: 900, easing: 'ease-out' },
      );
      for (const delay of [0, 180]) {
        const ring = document.createElement('span');
        ring.className = 'eq-ring';
        el.appendChild(ring);
        ring
          .animate(
            [
              { transform: 'translate(-50%,-50%) scale(0.15)', opacity: 0.55 },
              { transform: 'translate(-50%,-50%) scale(1)', opacity: 0 },
            ],
            { duration: 1100, delay, easing: 'cubic-bezier(0.2,0.6,0.3,1)', fill: 'forwards' },
          )
          .finished.then(() => ring.remove());
      }
    });
  }
  // park all shimmer while the hero is off-screen (WebKit perf guidance)
  const hero = document.querySelector('.hero');
  if (hero && !reduced) {
    new IntersectionObserver(([e]) => {
      for (const el of wraps) {
        const svg = el.querySelector('svg') as SVGSVGElement | null;
        if (!svg) continue;
        e.isIntersecting ? svg.unpauseAnimations() : svg.pauseAnimations();
      }
    }).observe(hero);
  }
</script>

<style>
  .bg-eq {
    position: absolute;
    user-select: none;
    pointer-events: auto; /* hover-to-freeze + click-burst need hit-testing */
    cursor: pointer;
    animation: eq-emerge 1.8s ease forwards;
    opacity: 0;
  }
  :global(.eq-ring) {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 34rem;
    height: 34rem;
    border-radius: 9999px;
    border: 1.5px solid color-mix(in srgb, var(--color-accent-soft) 70%, transparent);
    box-shadow:
      0 0 24px color-mix(in srgb, var(--color-accent) 45%, transparent),
      inset 0 0 18px color-mix(in srgb, var(--color-accent) 30%, transparent);
    pointer-events: none;
    transform: translate(-50%, -50%) scale(0.15);
    opacity: 0;
  }
  .eq-text {
    display: inline-block;
    color: color-mix(in srgb, var(--color-accent-soft) 55%, #e6eeff);
    text-shadow:
      0 0 18px color-mix(in srgb, var(--color-accent) 70%, transparent),
      0 0 4px rgba(230, 238, 255, 0.7);
  }
  html[data-theme='light'] .eq-text {
    color: color-mix(in srgb, var(--color-accent) 70%, #16203a);
    text-shadow: 0 0 12px color-mix(in srgb, var(--color-accent) 35%, transparent);
  }
  @keyframes eq-emerge {
    to {
      opacity: 0.34;
    }
  }
  html[data-theme='light'] .bg-eq {
    animation-name: eq-emerge-light;
  }
  @keyframes eq-emerge-light {
    to {
      opacity: 0.22;
    }
  }
  .eq-noether {
    top: 6%;
    left: 3%;
    font-size: 1.35rem;
    transform: rotate(-4deg);
    animation-delay: 0.2s;
  }
  .eq-path {
    bottom: 9%;
    right: 2%;
    font-size: 1.5rem;
    transform: rotate(2.5deg);
    animation-delay: 1.1s;
  }
  .eq-dirac {
    bottom: 21%;
    left: 8%;
    font-size: 1.25rem;
    transform: rotate(3deg);
    animation-delay: 0.65s;
  }
  .eq-efe {
    top: 11%;
    right: 6%;
    font-size: 1.4rem;
    transform: rotate(-2deg);
    animation-delay: 1.55s;
  }
  @media (prefers-reduced-motion: reduce) {
    .bg-eq {
      animation: none;
      opacity: 0.28;
    }
  }
  @media (max-width: 1024px) {
    .eq-path,
    .eq-efe {
      display: none;
    }
    .bg-eq {
      font-size: 1rem;
    }
  }
</style>
