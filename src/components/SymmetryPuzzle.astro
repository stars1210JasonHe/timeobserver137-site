---
/**
 * SymmetryPuzzle — 对称拼图.
 * v2 (2026-07-17, Yeqiu): 10 levels + a standing 「不可能」 declare button —
 * some targets are UNREACHABLE and recognizing that passes the level:
 *   · chirality levels: only rotations available, target is a mirror image —
 *     the C4 subgroup never crosses into the mirror coset (left hand ≠ right)
 *   · invariant levels: target is outside the D4 orbit entirely (a color
 *     count differs — symmetries move cells, never repaint them)
 * Reachability is decided by BFS with the level's own generators, par is BFS
 * distance — nothing is hand-labeled. All-10 completion fires a kaleidoscope
 * overlay: the eight D4 images of one tile assembling around the group's name.
 *
 * Runtime-created nodes ⟹ is:global styles (ChatWidget lesson).
 */
interface Props {
  lang: 'en' | 'zh';
}
const { lang } = Astro.props;
const zh = lang === 'zh';
---

<section class="mx-auto max-w-3xl px-6 py-12">
  <p class="text-sm uppercase tracking-[0.25em] text-muted">{zh ? '小游戏 · 对称拼图' : 'Play · Symmetry'}</p>
  <h1 class="mt-3 text-3xl font-semibold text-chalk">{zh ? '对称拼图' : 'Symmetry Puzzle'}</h1>
  <p class="mt-3 leading-relaxed text-muted">
    {zh
      ? '用旋转和翻转,把左边的图案变成右边的目标。但小心 —— 有的目标根本不可能到达,看穿它同样算你赢。正方形只有 8 种对称,它们连同组合规则构成数学里的「群」。'
      : 'Rotate and flip the left tile to match the target. But beware — some targets are flat-out unreachable, and seeing through them counts as a win. A square has exactly 8 symmetries; with composition they form a group.'}
  </p>

  <div class="sp-levels mt-6 flex flex-wrap items-center gap-2" role="tablist" aria-label={zh ? '关卡' : 'Levels'}></div>

  <div class="mt-4 grid grid-cols-[1fr_auto_1fr] items-center gap-3 sm:gap-6">
    <div class="sp-stage justify-self-end rounded-lg border border-line/70 bg-surface/40 p-3">
      <svg class="sp-board block h-auto w-[min(38vw,240px)]" viewBox="0 0 160 160"></svg>
    </div>
    <span class="text-2xl text-faint">→</span>
    <div class="justify-self-start rounded-lg border border-accent-soft/40 bg-surface/40 p-3">
      <svg class="sp-target block h-auto w-[min(30vw,180px)]" viewBox="0 0 160 160"></svg>
      <p class="mt-1 text-center text-xs text-faint">{zh ? '目标' : 'target'}</p>
    </div>
  </div>

  <div class="sp-ops mt-4 flex flex-wrap gap-2"></div>

  <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
    <p class="sp-status text-sm text-muted" aria-live="polite"></p>
    <div class="flex gap-2">
      <button class="sp-undo rounded-md border border-line px-3 py-1.5 text-sm text-ink transition-colors hover:border-accent-soft">{zh ? '撤销' : 'Undo'}</button>
      <button class="sp-reset rounded-md border border-line px-3 py-1.5 text-sm text-ink transition-colors hover:border-accent-soft">{zh ? '重来' : 'Reset'}</button>
      <button class="sp-declare rounded-md border border-accent-soft/60 px-3 py-1.5 text-sm text-accent-soft transition-colors hover:bg-accent/15">{zh ? '不可能' : 'Impossible'}</button>
    </div>
  </div>

  <div class="sp-note mt-4 hidden rounded-lg border border-accent-soft/50 bg-surface/60 p-5 text-sm leading-relaxed text-ink"></div>

  <p class="mt-6 text-sm text-muted">
    {zh
      ? <>这 8 个变换构成正方形的对称群 D₄ —— 《对称与怪兽》整个系列,就是沿着这架梯子往上爬。<a class="text-accent-soft underline underline-offset-2" href="/zh/series/symmetry-monster/">从第一集读起 →</a></>
      : <>These 8 moves form D₄, the symmetry group of the square — the Symmetry &amp; Monster series climbs this very ladder. <a class="text-accent-soft underline underline-offset-2" href="/zh/series/symmetry-monster/">Start from episode one →</a></>}
  </p>

  <div class="sp-fin fixed inset-0 z-50 hidden items-center justify-center bg-bg/90 backdrop-blur-sm">
    <div class="mx-6 max-w-md text-center">
      <div class="sp-fin-grid mx-auto grid w-64 grid-cols-3 gap-2"></div>
      <p class="mt-4 text-2xl font-semibold text-chalk">{zh ? '十关通过' : 'All ten levels'}</p>
      <p class="mt-2 text-muted">{zh ? '能拼的你都拼了,不可能的你都看穿了 —— 正方形的八种对称,现在都是你的。' : 'You solved every solvable tile and saw through every impossible one — the square’s eight symmetries are yours now.'}</p>
      <button class="sp-fin-close mt-6 rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-soft">{zh ? '收下' : 'Done'}</button>
    </div>
  </div>
</section>

<script>
  const __initOnLoad = () => {
    const board = document.querySelector<SVGSVGElement>('.sp-board');
    if (!board || board.dataset.wired) return;
    board.dataset.wired = '1';
    const targetSvg = document.querySelector<SVGSVGElement>('.sp-target')!;
    const zh = document.documentElement.lang.startsWith('zh');
    const statusEl = document.querySelector<HTMLElement>('.sp-status')!;
    const levelsEl = document.querySelector<HTMLElement>('.sp-levels')!;
    const opsEl = document.querySelector<HTMLElement>('.sp-ops')!;
    const noteEl = document.querySelector<HTMLElement>('.sp-note')!;
    const undoBtn = document.querySelector<HTMLButtonElement>('.sp-undo')!;
    const resetBtn = document.querySelector<HTMLButtonElement>('.sp-reset')!;
    const declareBtn = document.querySelector<HTMLButtonElement>('.sp-declare')!;
    const finEl = document.querySelector<HTMLElement>('.sp-fin')!;
    const t = (zhs: string, ens: string) => (zh ? zhs : ens);
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // --- D4 on a 4x4 grid of color indices ---
    const N = 4;
    type Pat = number[]; // 16 cells, row-major
    const rot = (p: Pat): Pat => p.map((_, i) => {
      const r = Math.floor(i / N), c = i % N;      // dest (r,c) ← src (N-1-c, r)
      return p[(N - 1 - c) * N + r];
    });
    const mirH = (p: Pat): Pat => p.map((_, i) => {
      const r = Math.floor(i / N), c = i % N;      // left-right flip
      return p[r * N + (N - 1 - c)];
    });
    const mirV = (p: Pat): Pat => p.map((_, i) => {
      const r = Math.floor(i / N), c = i % N;      // up-down flip
      return p[(N - 1 - r) * N + c];
    });
    const rotCCW = (p: Pat): Pat => rot(rot(rot(p)));

    type Op = { key: string; zh: string; en: string; fn: (p: Pat) => Pat; anim: string };
    const OPS: Record<string, Op> = {
      r: { key: 'r', zh: '↻ 转 90°', en: '↻ 90°', fn: rot, anim: 'rotate(90deg)' },
      l: { key: 'l', zh: '↺ 转 90°', en: '↺ 90°', fn: rotCCW, anim: 'rotate(-90deg)' },
      h: { key: 'h', zh: '↔ 左右翻', en: '↔ flip', fn: mirH, anim: 'scaleX(-1)' },
      v: { key: 'v', zh: '↕ 上下翻', en: '↕ flip', fn: mirV, anim: 'scaleY(-1)' },
    };

    // base patterns (0 = void, 1 = chalk, 2 = gold, 3 = blue); each must have
    // all 8 D4 images distinct or targets would be ambiguous — asserted below
    const P1: Pat = [
      2, 1, 0, 0,
      0, 1, 0, 0,
      0, 0, 3, 0,
      0, 0, 0, 3];
    const P2: Pat = [
      2, 2, 1, 0,
      0, 1, 0, 0,
      0, 3, 1, 0,
      3, 0, 0, 1];
    const P3: Pat = [
      1, 2, 3, 0,
      0, 1, 0, 3,
      0, 0, 1, 0,
      2, 0, 0, 1];

    const key = (p: Pat) => p.join('');
    const orbit8 = (p: Pat) => {
      const seen = new Set<string>();
      let cur = p;
      for (let i = 0; i < 4; i++) { seen.add(key(cur)); seen.add(key(mirH(cur))); cur = rot(cur); }
      return seen;
    };
    [P1, P2, P3].forEach((p, i) => {
      if (orbit8(p).size !== 8) console.error(`pattern P${i + 1} has a symmetry — only ${orbit8(p).size} distinct images`);
    });

    const apply = (p: Pat, word: string) => [...word].reduce((q, ch) => OPS[ch].fn(q), p);

    // L8's target: a legal-looking rotation with ONE gold cell repainted blue —
    // outside the whole D4 orbit; the tell is a color COUNT, the invariant
    const T_ALTERED: Pat = (() => {
      const q = apply(P3, 'r');
      const g = q.indexOf(2);
      q[g] = 3;
      return q;
    })();

    type Level = { name: string; en: string; pat: Pat; ops: string[]; word?: string; target?: Pat; showPar?: boolean };
    const LEVELS: Level[] = [
      { name: '转一下', en: 'One turn', pat: P1, word: 'r', ops: ['r', 'l', 'h', 'v'], showPar: true },
      { name: '照镜子', en: 'Mirror', pat: P1, word: 'h', ops: ['r', 'l', 'h', 'v'], showPar: true },
      { name: '转半圈', en: 'Half turn', pat: P1, word: 'rr', ops: ['r', 'l', 'h', 'v'], showPar: true },
      { name: '斜着照', en: 'Diagonal', pat: P2, word: 'rh', ops: ['r', 'l', 'h', 'v'], showPar: true },
      { name: '镜中世界', en: 'Mirror world', pat: P2, word: 'h', ops: ['r', 'l'] },   // chirality: rotations never mirror
      { name: '绕远路', en: 'The long way', pat: P2, word: 'l', ops: ['r', 'h'] },     // par 3: rrr or hrh
      { name: '三步一镜', en: 'Three for one', pat: P3, word: 'rhr', ops: ['r', 'h'] }, // par 3
      { name: '冒牌货', en: 'The impostor', pat: P3, target: T_ALTERED, ops: ['r', 'l', 'h', 'v'] }, // invariant: repainted cell
      { name: '别扭的工具', en: 'Odd tools', pat: P1, word: 'h', ops: ['l', 'v'] },    // par 3 with odd generators
      { name: '左手与右手', en: 'Left hand, right hand', pat: P3, word: 'rh', ops: ['r', 'l'] }, // finale chirality
    ];
    const goalOf = (l: Level) => l.target ?? apply(l.pat, l.word!);

    // honest reachability + par: BFS with THIS level's generators
    const bfs = (l: Level) => {
      const goal = key(goalOf(l));
      const decode = (s: string) => [...s].map(Number);
      let frontier: [string, string][] = [[key(l.pat), '']];
      const seen = new Set([frontier[0][0]]);
      while (frontier.length) {
        const nf: [string, string][] = [];
        for (const [s, w] of frontier) {
          if (s === goal) return { par: w.length, word: w };
          for (const op of l.ops) {
            const nk = key(OPS[op].fn(decode(s)));
            if (!seen.has(nk)) { seen.add(nk); nf.push([nk, w + op]); }
          }
        }
        frontier = nf;
      }
      return { par: Infinity, word: '' };
    };
    const isImpossible = (l: Level) => bfs(l).par === Infinity;

    const store = {
      read(): { done: number[] } {
        try { return JSON.parse(localStorage.getItem('symmetry-v1') || '{"done":[]}'); }
        catch { return { done: [] }; }
      },
      markDone(i: number) {
        const s = store.read();
        if (!s.done.includes(i)) s.done.push(i);
        localStorage.setItem('symmetry-v1', JSON.stringify(s));
      },
    };

    const COLORS = ['transparent', 'var(--color-chalk)', '#dda25b', 'var(--color-accent-soft)'];
    const NS = 'http://www.w3.org/2000/svg';
    const drawPat = (svg: SVGSVGElement, p: Pat) => {
      svg.innerHTML = '';
      const cell = 160 / N;
      for (let i = 0; i <= N; i++) {
        const mk = (x1: number, y1: number, x2: number, y2: number) => {
          const ln = document.createElementNS(NS, 'line');
          ln.setAttribute('x1', String(x1)); ln.setAttribute('y1', String(y1));
          ln.setAttribute('x2', String(x2)); ln.setAttribute('y2', String(y2));
          ln.setAttribute('stroke', 'var(--color-line)');
          ln.setAttribute('stroke-width', '1');
          svg.appendChild(ln);
        };
        mk(i * cell, 0, i * cell, 160);
        mk(0, i * cell, 160, i * cell);
      }
      p.forEach((c, i) => {
        if (!c) return;
        const r = Math.floor(i / N), col = i % N;
        const rect = document.createElementNS(NS, 'rect');
        rect.setAttribute('x', String(col * cell + 3));
        rect.setAttribute('y', String(r * cell + 3));
        rect.setAttribute('width', String(cell - 6));
        rect.setAttribute('height', String(cell - 6));
        rect.setAttribute('rx', '4');
        rect.setAttribute('fill', COLORS[c]);
        rect.setAttribute('opacity', c === 1 ? '0.9' : '0.85');
        svg.appendChild(rect);
      });
    };

    let cur = 0;
    let state: Pat = [];
    let moves: string[] = [];
    let animating = false;

    const level = () => LEVELS[cur];
    const goal = () => goalOf(level());

    const renderLevelDots = () => {
      levelsEl.innerHTML = '';
      const done = store.read().done;
      LEVELS.forEach((l, i) => {
        const b = document.createElement('button');
        b.className = 'os-lvl';
        b.textContent = `${i + 1}. ${zh ? l.name : l.en}`;
        b.classList.toggle('active', i === cur);
        b.classList.toggle('done', done.includes(i));
        b.addEventListener('click', () => { cur = i; setup(); });
        levelsEl.appendChild(b);
      });
    };

    const renderOps = () => {
      opsEl.innerHTML = '';
      level().ops.forEach((k) => {
        const op = OPS[k];
        const b = document.createElement('button');
        b.className = 'sp-op';
        b.textContent = zh ? op.zh : op.en;
        b.addEventListener('click', () => doOp(op));
        opsEl.appendChild(b);
      });
    };

    const wordPretty = (w: string) => [...w].map((ch) => (zh ? OPS[ch].zh : OPS[ch].en).split(' ')[0]).join(' · ') || t('(不动)', '(nothing)');
    const setStatus = (m: string) => { statusEl.textContent = m; };
    const note = (html: string) => { noteEl.innerHTML = html; noteEl.classList.remove('hidden'); };

    const setup = () => {
      state = [...level().pat];
      moves = [];
      noteEl.classList.add('hidden');
      drawPat(board, state);
      drawPat(targetSvg, goal());
      renderLevelDots();
      renderOps();
      const { par } = bfs(level());
      setStatus(level().showPar
        ? t(`最少 ${par} 步。`, `Par: ${par} move(s).`)
        : t('拼出来 —— 或者看穿它,按「不可能」。', 'Solve it — or see through it and press Impossible.'));
    };

    const maybeCelebrate = () => {
      if (store.read().done.length !== LEVELS.length) return;
      const grid = finEl.querySelector<HTMLElement>('.sp-fin-grid')!;
      grid.innerHTML = '';
      // the eight D4 images of P2 assemble around the group's name
      const words = ['', 'r', 'rr', 'rrr', 'h', 'rh', 'rrh', 'rrrh'];
      const cells: (Pat | null)[] = [
        apply(P2, words[0]), apply(P2, words[1]), apply(P2, words[2]),
        apply(P2, words[7]), null, apply(P2, words[3]),
        apply(P2, words[6]), apply(P2, words[5]), apply(P2, words[4]),
      ];
      cells.forEach((p, i) => {
        if (!p) {
          const d = document.createElement('div');
          d.className = 'sp-fin-center flex items-center justify-center text-2xl font-semibold text-chalk';
          d.textContent = 'D₄';
          grid.appendChild(d);
          return;
        }
        const svg = document.createElementNS(NS, 'svg') as SVGSVGElement;
        svg.setAttribute('viewBox', '0 0 160 160');
        svg.setAttribute('class', 'sp-fin-tile');
        svg.style.animationDelay = `${0.18 * i}s`;
        drawPat(svg, p);
        grid.appendChild(svg);
      });
      finEl.classList.remove('hidden');
      finEl.classList.add('flex');
    };
    finEl.querySelector('.sp-fin-close')!.addEventListener('click', () => {
      finEl.classList.add('hidden');
      finEl.classList.remove('flex');
    });

    const passLevel = () => {
      store.markDone(cur);
      renderLevelDots();
      maybeCelebrate();
    };

    const checkWin = () => {
      if (key(state) !== key(goal())) return;
      const { par, word: sw } = bfs(level());
      const star = moves.length === par;
      passLevel();
      setStatus(star ? t(`★ ${moves.length} 步,最短解!`, `★ Solved in ${moves.length} — that's par!`)
        : t(`✓ ${moves.length} 步通关(最少 ${par} 步)。`, `✓ Solved in ${moves.length} (par ${par}).`));
      if (moves.length > par || sw.length > 1) {
        note(
          `<p>${t('你的解:', 'Your word: ')}${wordPretty(moves.join(''))}</p>` +
          `<p class="mt-1">${t('一个最短解:', 'A shortest word: ')}${wordPretty(sw)}</p>` +
          `<p class="mt-2" style="color:var(--color-muted)">${t('不同的步骤串,同一个变换 —— 「乘法表」就是这样长出来的,这就是群。', 'Different move-strings, one transformation — that is how a multiplication table is born. That is a group.')}</p>`,
        );
      }
    };

    const doOp = (op: Op) => {
      if (animating) return;
      const after = op.fn(state);
      moves.push(op.key);
      if (reduced) {
        state = after;
        drawPat(board, state);
        checkWin();
        return;
      }
      animating = true;
      board.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
      board.style.transform = op.anim;
      setTimeout(() => {
        board.style.transition = 'none';
        board.style.transform = 'none';
        state = after;
        drawPat(board, state);
        animating = false;
        checkWin();
      }, 310);
    };

    declareBtn.addEventListener('click', () => {
      const l = level();
      const { par } = bfs(l);
      if (par !== Infinity) {
        declareBtn.classList.remove('shake');
        void declareBtn.getBoundingClientRect();
        declareBtn.classList.add('shake');
        setStatus(t(`其实到得了 —— 最少 ${par} 步。再试试。`, `It IS reachable — par ${par}. Keep trying.`));
        return;
      }
      passLevel();
      // which impossibility? in the full D4 orbit ⟹ chirality; outside ⟹ invariant
      const inD4 = orbit8(l.pat).has(key(goalOf(l)));
      setStatus(t('✓ 看穿了 —— 这个目标真的到不了。', '✓ Seen through — this target really is unreachable.'));
      note(inD4
        ? `<p class="font-medium" style="color:var(--color-chalk)">${t('手性:旋转到不了镜子里', 'Chirality: rotations never enter the mirror')}</p>` +
          `<p class="mt-2">${t('只用旋转,图案永远是「同一只手」;目标是它的镜像 —— 另一只手。四个旋转 {不动, 90°, 180°, 270°} 自成封闭的小圈(子群 C₄),镜像世界整个在圈外,只有翻转能跨过去。左手转一辈子,也变不成右手。', 'With rotations alone the tile stays the "same hand"; the target is its mirror image — the other hand. The four rotations form a closed little circle (the subgroup C₄); the mirror world lies entirely outside it, and only a flip crosses over. A left hand can spin forever and never become a right hand.')}</p>`
        : `<p class="font-medium" style="color:var(--color-chalk)">${t('不变量:对称只搬格子,不换颜色', 'Invariants: symmetries move cells, never repaint them')}</p>` +
          `<p class="mt-2">${t('数一数两边每种颜色的格子数 —— 对不上。旋转和翻转只会搬动格子,数量是它们动不了的「不变量」。识破一个根本不在轨道上的目标,靠的就是找不变量:这也是数学家判定「不可能」的标准手法。', 'Count the cells of each color on both sides — they disagree. Rotations and flips only move cells; the counts are an invariant they cannot touch. Spotting a target that is off the orbit entirely is done exactly this way — invariants are how mathematicians prove "impossible".')}</p>`);
    });

    undoBtn.addEventListener('click', () => {
      if (animating || !moves.length) return;
      moves.pop();
      state = apply([...level().pat], moves.join(''));
      drawPat(board, state);
      setStatus(t('退了一步。', 'Stepped back.'));
    });
    resetBtn.addEventListener('click', setup);

    setup();
  };
  // register for future swaps AND run now — if this script was swapped in
  // by ClientRouter, this navigation's astro:page-load has already fired
  document.addEventListener('astro:page-load', __initOnLoad);
  __initOnLoad();
</script>

<style is:global>
  .sp-op {
    border: 1px solid var(--color-line);
    border-radius: 0.375rem;
    padding: 0.45rem 0.9rem;
    font-size: 0.9rem;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-surface) 55%, transparent);
    transition: border-color 0.15s, background 0.15s;
  }
  .sp-op:hover { border-color: var(--color-accent-soft); background: var(--color-surface); }
  .sp-op:active { transform: scale(0.96); }
  .sp-fin-tile {
    width: 100%;
    height: auto;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-surface) 60%, transparent);
    opacity: 0;
    transform: scale(0.4) rotate(-90deg);
    animation: sp-fin-in 0.5s cubic-bezier(0.34, 1.3, 0.64, 1) forwards;
  }
  .sp-fin-center { min-height: 3rem; }
  @keyframes sp-fin-in {
    to { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .sp-fin-tile { animation: none; opacity: 1; transform: none; }
  }
</style>
