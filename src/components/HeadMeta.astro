---
/**
 * Per-page head metadata with the site-level OG fallback chain.
 * og:image = page-specific image ?? timeobserver cover (parity with Ghost:
 * 14/18 legacy posts had no feature_image and fell back to the site cover —
 * spec §3 "OG 分享卡" row requires this exact behavior to survive migration).
 */
interface Props {
  title: string;
  description: string;
  lang: 'en' | 'zh';
  ogImage?: string;
  path: string; // pathname for canonical, e.g. "/zh/writing/foo/"
}
const { title, description, lang, ogImage, path } = Astro.props;
const site = Astro.site ?? new URL('https://timeobserver137.cyou');
const canonical = new URL(path, site).href;
const ogAbs = new URL(ogImage ?? '/og/timeobserver-og-fixed.png', site).href;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/favicon.png" />
<link rel="alternate" type="application/rss+xml" title="时间观察者" href="/rss.xml" />

<meta property="og:site_name" content="时间观察者" />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogAbs} />
<meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_AU'} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@HugoStars1210" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogAbs} />
