---
/**
 * Homepage motion layer.
 * Phase 1 (2026-07-16): scroll reveals + pointer parallax on the Lagrange figure.
 * Phase 2 (2026-07-17, Yeqiu 「太单调 → showcase 级」): scroll narrative —
 *   background equations drift at different depths while scrolling (the void
 *   acquires parallax), the |M| monument settles digit-cluster by digit-cluster,
 *   and the hero eases back as you leave it.
 * All motion is scroll/pointer-driven (user-initiated — the draw-once-then-still
 * spec rule only constrains autonomous animation); prefers-reduced-motion
 * disables everything (tokens.css keeps [data-reveal] content visible).
 */
---

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initHome() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const hero = document.querySelector<HTMLElement>('.hero');
    // Element-scoped guard FIRST (before any kill): this runs twice on a cold
    // load — once at module eval, once on astro:page-load — and a second pass
    // over the SAME dom used to restart the entrance mid-flight. Bailing here
    // leaves the first pass's triggers alive; a real swap brings a fresh .hero
    // with no flag, so navigation still re-initialises.
    if (hero?.dataset.motionWired) return;
    // stale triggers from the page we just left point at dead nodes
    ScrollTrigger.getAll().forEach((st) => st.kill());
    if (!hero) return;
    hero.dataset.motionWired = '1';
    gsap.registerPlugin(ScrollTrigger);

    // --- phase 3: hero entrance — one brief stagger on load (<1s total) ---
    // fromTo, NOT from: from() captures the element's CURRENT opacity as its
    // destination, so a re-run mid-tween pins the headline at whatever partial
    // value it had reached (that bug hid the h1 entirely in Safari, 2026-07-18).
    gsap.fromTo(
      '[data-hero-stagger]',
      { opacity: 0, y: 14 },
      { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out', stagger: 0.09, overwrite: 'auto' },
    );

    // --- reveals (phase 1) ---
    for (const el of document.querySelectorAll('[data-reveal]')) {
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 88%', once: true },
      });
    }

    // hero content eases back as you scroll past it
    const heroInner = document.querySelector('.hero > div');
    if (heroInner) {
      gsap.to(heroInner, {
        opacity: 0.25,
        yPercent: -6,
        ease: 'none',
        scrollTrigger: { trigger: '.hero', start: '40% top', end: 'bottom top', scrub: 0.4 },
      });
    }

    // --- phase 1: pointer parallax on the Lagrange figure ---
    const fig = document.querySelector<HTMLElement>('.lagrange');
    if (fig && matchMedia('(pointer: fine)').matches) {
      const setX = gsap.quickTo(fig, 'rotationY', { duration: 0.6, ease: 'power2.out' });
      const setY = gsap.quickTo(fig, 'rotationX', { duration: 0.6, ease: 'power2.out' });
      gsap.set(fig, { transformPerspective: 900 });
      hero.addEventListener('pointermove', (ev) => {
        const r = hero.getBoundingClientRect();
        setX(((ev.clientX - r.left) / r.width - 0.5) * 7);
        setY(-((ev.clientY - r.top) / r.height - 0.5) * 5);
      });
      hero.addEventListener('pointerleave', () => {
        setX(0);
        setY(0);
      });
    }
  }

  document.addEventListener('astro:page-load', initHome);
  initHome();
</script>