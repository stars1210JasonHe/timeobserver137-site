---
/**
 * The formula canon wall (spec §6: 「宇宙的公式肯定要的」— Yeqiu's personal
 * physics canon, deployed on About per the anti-symbol-soup discipline:
 * four SENTENCES each carrying one equation — identity narrative, not a
 * greatest-hits poster. Order: Noether leads (passes both criteria; carries
 * the EN link so its corpus leg is visible to EN readers — Socrates' guard).
 * KaTeX rendered at BUILD time via renderToString — zero runtime JS.
 */
import katex from 'katex';
import 'katex/dist/katex.min.css';

interface Props {
  lang: 'en' | 'zh';
}
const { lang } = Astro.props;
const zh = lang === 'zh';

const k = (tex: string) => katex.renderToString(tex, { displayMode: true, throwOnError: false });

// NOTE FOR YEQIU: the four quotes below are Euler's DRAFTS — replace with your own words.
const canon = [
  {
    name: zh ? 'Noether 定理' : "Noether's theorem",
    tex: '\\frac{d}{dt}\\!\\left(\\frac{\\partial L}{\\partial \\dot{q}}\\,\\delta q\\right) = 0',
    quote: zh
      ? '对称与守恒是同一件事的两面——我的整个《对称与怪兽》系列，都是在给这句话做注脚。'
      : 'Symmetry and conservation are two faces of one fact — my entire Symmetry & Monster series is a footnote to this line.',
    link: { href: zh ? '/zh/writing/' : '/writing/', label: zh ? '《对称与怪兽》系列 →' : 'the Symmetry & Monster series →' },
  },
  {
    name: zh ? '路径积分' : 'The path integral',
    tex: '\\langle x_f | e^{-iHt/\\hbar} | x_i \\rangle = \\int \\mathcal{D}[x(t)]\\, e^{iS[x]/\\hbar}',
    quote: zh
      ? '所有可能的历史各自贡献一个相位——没有比这更民主的物理。'
      : 'Every possible history contributes a phase — physics has never been more democratic.',
  },
  {
    name: zh ? 'Dirac 方程' : 'The Dirac equation',
    tex: '(i\\gamma^\\mu \\partial_\\mu - m)\\,\\psi = 0',
    quote: zh
      ? '把相对论和量子力学压进一行，还顺手预言了反物质。优雅是有预言力的。'
      : 'Relativity and quantum mechanics compressed into one line — and antimatter predicted as a side effect. Elegance has predictive power.',
  },
  {
    name: zh ? '爱因斯坦场方程' : "Einstein's field equations",
    tex: 'G_{\\mu\\nu} + \\Lambda g_{\\mu\\nu} = \\frac{8\\pi G}{c^4} T_{\\mu\\nu}',
    quote: zh
      ? '几何即引力。物理学最漂亮的一次「原来如此」。'
      : "Geometry is gravity. Physics' most beautiful 'so that's why'.",
  },
];
---

<section class="mx-auto max-w-2xl px-6 py-16">
  <h2 class="mb-2 text-2xl font-semibold text-chalk">{zh ? '四个公式' : 'Four equations'}</h2>
  <p class="mb-10 text-sm text-muted">
    {zh ? '如果只许我在墙上挂四件东西。' : 'If I were allowed only four things on my wall.'}
  </p>
  <div class="space-y-12">
    {canon.map((c) => (
      <figure>
        <div class="equation overflow-x-auto py-2 text-chalk" set:html={k(c.tex)} />
        <figcaption class="mt-3 text-sm leading-relaxed text-muted">
          <span class="font-medium text-ink">{c.name}.</span> {c.quote}
          {c.link && (
            <a class="ml-1 text-accent-soft underline underline-offset-2" href={c.link.href}>{c.link.label}</a>
          )}
        </figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .equation :global(.katex-display) {
    margin: 0;
    text-align: left;
  }
  .equation :global(.katex) {
    font-size: 1.35rem;
  }
</style>
